# Supabase — projeto dedicado ao Companion (Decisão A1 da Architecture)
# Gere um projeto novo em https://supabase.com/dashboard e copie as 3 strings
# abaixo. Nunca reaproveite credenciais de outros projetos.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key — bypassa RLS. Apenas server-side, nunca exposta ao bundle
# do cliente. Validação automatizada do bundle entra em T-005.
SUPABASE_SERVICE_ROLE_KEY=